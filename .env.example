# .env example file for local development. Not used in production.
# In CI, these are set via GitHub Actions repository variables.

# Salesforce API proxy worker (project-specific worker that handles /sf/* routes)
PUBLIC_WORKER_URL=https://sf-api-version-updater.<your-account>.workers.dev

# Generic OAuth broker worker (sf-oauth-broker project that handles /oauth/* routes)
PUBLIC_BROKER_URL=https://sf-oauth-broker.<your-account>.workers.dev
